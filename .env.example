APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Bogota
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Vacío en dev: el SDK de Sentry no envía nada sin DSN. En producción,
# definir para que las excepciones de request y de jobs en cola dejen de
# reportarse solo al log local (ver Integration::handles en bootstrap/app.php).
SENTRY_LARAVEL_DSN=

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# file: sin dependencias extra, rápido para dev local. En producción con
# más de un servidor web (o para evitar N queries de sesión por request),
# cambiar a 'redis' — ver REDIS_CLIENT más abajo.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Sin definir, config/session.php ya la fuerza a true fuera de local/testing —
# dejar así en dev; en producción setear explícitamente SESSION_SECURE_COOKIE=true
# si se sirve detrás de un proxy que termina TLS (para que el override no dependa
# de que app()->environment() detecte bien el entorno).
SESSION_SECURE_COOKIE=

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Reverb (tiempo real de designaciones) — en cada máquina correr
# `php artisan reverb:install` para generar APP_ID/KEY/SECRET propios,
# no copiar los mismos valores entre entornos.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Igual que SESSION_DRIVER: 'file' para dev local, 'redis' en producción
# (Spatie Permission también cachea acá — con 'database' cada chequeo de
# permiso es una query más).
CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# predis: cliente 100% PHP, no necesita la extensión phpredis compilada —
# más portable entre distintos hosts de producción.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# 'log' en dev local (los correos quedan en storage/logs/laravel.log, nadie
# los recibe de verdad). En producción, cambiar a 'resend' y definir
# RESEND_API_KEY más abajo — 'resend' ya está registrado en config/mail.php.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@novareef.com
MAIL_FROM_NAME="NovaReef"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
ADMIN_PREFIX=novareef-panel
ADMIN_MAX_INTENTOS=3
ADMIN_BLOQUEO_SEGUNDOS=300
RESEND_API_KEY=
# Sin esto, el endpoint de webhook de Resend queda sin firma verificada en
# producción (hoy es inerte, sin listeners registrados, pero es una puerta
# sin autenticar si algún día se agrega uno). Copiar el secreto que Resend
# genera al crear el webhook en su dashboard.
RESEND_WEBHOOK_SECRET=
